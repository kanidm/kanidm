# This should be at /etc/kanidm/config or ~/.config/kanidm,
# and configures kanidm clients including the FreeRADIUS server

uri = "https://idm.example.com"

# an optional path to the CA certificate for the server URI above
# ca_path = "/etc/kanidm/cacert.pem"

# The client connection timeout, in seconds.
connect_timeout = 30

# enable (default) or disable TLS certificate hostname verification. The certificate
# authority is still verified and must be valid.
# verify_hostnames = true

# Enable (default) or disable TLS certificate authority verification.
# Setting this to FALSE effectively opens the door to any attacker being
# able to perform an MITM attack. You should only set this to FALSE in
# extreme circumstances.
# verify_ca = true

